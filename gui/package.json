{
	"name": "gui",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"tauri": "sh -c 'tauri \"$@\"; RC=$?; [ $RC -eq 0 ] && [ \"$1\" = \"build\" ] && { DEB=$(ls src-tauri/target/release/bundle/deb/*.deb 2>/dev/null | head -1); echo \"\"; echo \"Install with:\"; echo \"  sudo apt install ./$DEB\"; }; exit $RC' sh"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"jsdom": "^28.1.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/cli": "^2.10.1"
	}
}
